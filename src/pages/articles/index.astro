---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = await getCollection('articles', ({ data }) => data.status === 'live');
articles.sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime());

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title="Articles — Chain Brief"
  description="Crypto explainers, protocol deep dives, and market briefs from Chain Brief."
>
  <div class="page-header">
    <h1 class="page-title">Articles</h1>
    <p class="page-sub">Crypto explainers, protocol deep dives, and weekly market briefs.</p>
  </div>

  {articles.length > 0 ? (
    <div class="article-list">
      {articles.map(article => (
        <a href={`/articles/${article.slug}`} class="article-row">
          <div class="article-info">
            <div class="article-meta">
              <span class="article-cat">{article.data.category}</span>
              <span class="article-date">{formatDate(article.data.publishedDate)}</span>
            </div>
            <h2 class="article-title">{article.data.title}</h2>
            <p class="article-desc">{article.data.description}</p>
          </div>
          <div class="article-arrow" aria-hidden="true">&#8594;</div>
        </a>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <p class="empty-title">First article coming soon</p>
      <p class="empty-sub">Subscribe to get notified when we launch.</p>
      <div class="subscribe-form" style="margin:1.5rem auto 0; max-width:380px;">
        <input type="email" placeholder="your@email.com" aria-label="Email address" />
        <button class="btn">Notify me</button>
      </div>
    </div>
  )}
</BaseLayout>

<style>
  .page-header {
    padding: 2rem 0 2.5rem;
    border-bottom: 1px solid var(--brand-border);
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }

  .page-sub {
    color: var(--brand-muted);
    font-size: 0.9375rem;
  }

  .article-list {
    display: flex;
    flex-direction: column;
  }

  .article-row {
    display: flex;
    gap: 1rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--brand-border);
    text-decoration: none;
    color: inherit;
    align-items: flex-start;
  }

  .article-row:first-child { padding-top: 0; }
  .article-row:hover .article-title { color: var(--brand-accent); }

  .article-info { flex: 1; min-width: 0; }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
  }

  .article-cat {
    font-size: 0.675rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-accent);
  }

  .article-date {
    font-size: 0.75rem;
    color: var(--brand-muted);
  }

  .article-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    line-height: 1.3;
    color: var(--brand-text);
    transition: color 0.15s;
  }

  .article-desc {
    font-size: 0.875rem;
    color: var(--brand-muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-arrow {
    color: var(--brand-border);
    font-size: 1.1rem;
    align-self: center;
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }

  .article-row:hover .article-arrow {
    color: var(--brand-accent);
    transform: translateX(3px);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 0;
    border: 1px dashed var(--brand-border);
    border-radius: 12px;
  }

  .empty-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .empty-sub {
    color: var(--brand-muted);
  }

  @media (max-width: 600px) {
    .article-arrow { display: none; }
    .article-desc { display: none; }
  }
</style>
