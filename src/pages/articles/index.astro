---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = await getCollection('articles', ({ data }) => data.status === 'live');
articles.sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime());

const categories = [...new Set(articles.map(a => a.data.category))].sort();

const articlesJson = JSON.stringify(articles.map(a => ({
  slug: a.slug,
  title: a.data.title,
  description: a.data.description,
  category: a.data.category,
  publishedDate: a.data.publishedDate,
})));

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title="Archive — Chain Brief"
  description="Crypto explainers, protocol deep dives, and market briefs from Chain Brief."
>
  <div class="page-header">
    <div class="header-meta">
      <span class="header-tag">&gt; TRANSMISSION_ARCHIVE</span>
      <span class="header-count" id="record-count">{articles.length} RECORDS</span>
    </div>
    <h1 class="page-title">ARCHIVE</h1>
    <div class="category-bar">
      <button class="cat-pill active" data-category="all">[ALL]</button>
      {categories.map(cat => (
        <button class="cat-pill" data-category={cat}>[{cat}]</button>
      ))}
    </div>
  </div>

  {articles.length > 0 ? (
    <div class="article-list" id="article-list">
      {articles.map((article, i) => (
        <a
          href={`/articles/${article.slug}`}
          class="article-row"
          data-category={article.data.category}
        >
          <div class="row-left">
            <span class="article-num">{String(i + 1).padStart(3, '0')}</span>
          </div>
          <div class="article-body">
            <div class="article-meta">
              <span class="cat-tag">[{article.data.category}]</span>
              <span class="article-date">{formatDate(article.data.publishedDate)}</span>
            </div>
            <h2 class="article-title">{article.data.title}</h2>
            <p class="article-desc">{article.data.description}</p>
          </div>
          <div class="row-right">
            <span class="article-arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <p class="empty-code">// NO_RECORDS_FOUND</p>
      <p class="empty-sub">First transmission incoming. Subscribe for launch notification.</p>
    </div>
  )}

  <div id="empty-filter" class="filter-empty" style="display:none">
    <p class="empty-code">// NO_RECORDS_IN_CATEGORY</p>
    <p class="empty-sub">No articles in this category yet. <button class="reset-link" id="reset-filter">Show all</button></p>
  </div>
</BaseLayout>

<script define:vars={{ articlesJson }}>
  const articles = JSON.parse(articlesJson);
  const pills = document.querySelectorAll('.cat-pill');
  const rows = document.querySelectorAll('.article-row');
  const countEl = document.getElementById('record-count');
  const emptyFilter = document.getElementById('empty-filter');
  const articleList = document.getElementById('article-list');
  const resetBtn = document.getElementById('reset-filter');

  function filterBy(category) {
    pills.forEach(p => p.classList.toggle('active', p.dataset.category === category));

    let visible = 0;
    rows.forEach(row => {
      const match = category === 'all' || row.dataset.category === category;
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    countEl.textContent = visible + ' RECORDS';

    if (visible === 0) {
      articleList.style.display = 'none';
      emptyFilter.style.display = 'block';
    } else {
      articleList.style.display = '';
      emptyFilter.style.display = 'none';
    }

    // Renumber visible rows
    let n = 1;
    rows.forEach(row => {
      if (row.style.display !== 'none') {
        row.querySelector('.article-num').textContent = String(n++).padStart(3, '0');
      }
    });
  }

  pills.forEach(pill => {
    pill.addEventListener('click', () => filterBy(pill.dataset.category));
  });

  if (resetBtn) resetBtn.addEventListener('click', () => filterBy('all'));

  // Activate category from URL hash, e.g. /articles#Market+Brief
  const hash = decodeURIComponent(location.hash.slice(1));
  if (hash && articles.some(a => a.category === hash)) filterBy(hash);
</script>

<style>
  .page-header {
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border-bright);
    margin-bottom: 0;
  }

  .header-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .header-tag {
    font-size: 0.65rem;
    color: var(--neon);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .header-count {
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .page-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3rem, 10vw, 5.5rem);
    letter-spacing: -0.01em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--text);
    text-shadow: var(--neon-glow);
    margin-bottom: 1.25rem;
  }

  .category-bar {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .cat-pill {
    font-size: 0.6rem;
    font-family: var(--font-mono);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border-bright);
    padding: 0.2rem 0.6rem;
    background: none;
    cursor: pointer;
    transition: color 0.12s, border-color 0.12s, background 0.12s;
  }

  .cat-pill:hover,
  .cat-pill.active {
    color: var(--neon);
    border-color: var(--neon);
    background: rgba(0, 255, 65, 0.06);
  }

  /* ── LIST ── */
  .article-list {
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--border-bright);
    border-right: 1px solid var(--border-bright);
  }

  .article-row {
    display: grid;
    grid-template-columns: 3.5rem 1fr 2rem;
    padding: 1.5rem 1rem;
    border-bottom: 1px solid var(--border-bright);
    text-decoration: none;
    color: inherit;
    align-items: center;
    transition: background 0.1s;
    position: relative;
    gap: 1rem;
  }

  .article-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--neon);
    transform: scaleY(0);
    transition: transform 0.15s;
    box-shadow: var(--neon-glow);
  }

  .article-row:hover { background: var(--surface); }
  .article-row:hover::before { transform: scaleY(1); }

  .row-left { display: flex; align-items: flex-start; padding-top: 0.1rem; }

  .article-num {
    font-size: 0.65rem;
    color: var(--neon);
    opacity: 0.4;
    letter-spacing: 0.05em;
    font-variant-numeric: tabular-nums;
  }

  .article-body { min-width: 0; }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .cat-tag {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--neon);
    text-transform: uppercase;
  }

  .article-date {
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  .article-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 0.35rem;
    transition: color 0.1s;
  }

  .article-row:hover .article-title { color: var(--neon); }

  .article-desc {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .row-right { display: flex; align-items: center; justify-content: flex-end; }

  .article-arrow {
    color: var(--muted);
    font-size: 1rem;
    transition: color 0.1s, transform 0.1s;
  }

  .article-row:hover .article-arrow {
    color: var(--neon);
    transform: translateX(3px);
  }

  /* ── EMPTY ── */
  .empty-state,
  .filter-empty {
    padding: 3rem 0 3rem 2rem;
    border: 1px solid var(--border-bright);
    border-left: 4px solid var(--neon);
    margin-top: 2rem;
  }

  .empty-code {
    font-size: 0.75rem;
    color: var(--neon);
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
    opacity: 0.7;
    font-family: var(--font-mono);
  }

  .empty-sub {
    font-size: 0.875rem;
    color: var(--muted);
  }

  .reset-link {
    background: none;
    border: none;
    color: var(--neon);
    cursor: pointer;
    font-size: inherit;
    padding: 0;
    text-decoration: underline;
    font-family: inherit;
  }

  @media (max-width: 600px) {
    .article-row { grid-template-columns: 2.5rem 1fr; }
    .row-right { display: none; }
    .article-desc { -webkit-line-clamp: 1; }
  }
</style>
