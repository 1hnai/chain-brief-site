---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Chain Brief"
  description="Crypto made clear — from first principles to the latest signals. The independent crypto briefing for curious, intelligent readers."
>
  <section style="text-align:center; padding: 4rem 0 3rem;">
    <p style="font-size:0.85rem; font-weight:600; text-transform:uppercase; letter-spacing:0.1em; color:var(--brand-accent); margin-bottom:1rem;">Crypto Intelligence</p>
    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:800; line-height:1.15; letter-spacing:-0.03em; margin-bottom:1.25rem;">
      Crypto made clear —<br>from first principles to the latest signals.
    </h1>
    <p style="font-size:1.1rem; color:var(--brand-muted); max-width:520px; margin:0 auto 2.5rem;">
      Whether you're new to crypto or deep in the ecosystem, Chain Brief gives you the
      <strong style="color:var(--brand-text)">clearest possible read</strong> on what's happening and why it matters.
      No trading advice. Just signal.
    </p>
    <div class="subscribe-form" style="margin:0 auto; max-width:420px;">
      <input type="email" placeholder="your@email.com" aria-label="Email address" />
      <button class="btn">Subscribe free</button>
    </div>
    <p style="font-size:0.8rem; color:var(--brand-muted); margin-top:0.75rem;">Free. Independent. Not financial advice.</p>
  </section>

  <hr style="border:none; border-top:1px solid var(--brand-border); margin: 2rem 0;" />

  <section style="margin: 3rem 0;">
    <h2 style="font-size:0.85rem; font-weight:700; margin-bottom:1.5rem; color:var(--brand-muted); text-transform:uppercase; letter-spacing:0.05em;">What we cover</h2>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap:1.5rem;">
      <div style="background:var(--brand-surface); border:1px solid var(--brand-border); border-radius:10px; padding:1.25rem;">
        <div style="font-size:1.5rem; margin-bottom:0.5rem;">📰</div>
        <h3 style="font-weight:700; margin-bottom:0.4rem;">Daily Market Brief</h3>
        <p style="font-size:0.9rem; color:var(--brand-muted);">The week's crypto news that matters — summarised clearly, without the noise.</p>
      </div>
      <div style="background:var(--brand-surface); border:1px solid var(--brand-border); border-radius:10px; padding:1.25rem;">
        <div style="font-size:1.5rem; margin-bottom:0.5rem;">🎓</div>
        <h3 style="font-weight:700; margin-bottom:0.4rem;">Chain 101</h3>
        <p style="font-size:0.9rem; color:var(--brand-muted);">Bi-weekly beginner guides: blockchains, wallets, DeFi, Layer 2s — explained from first principles.</p>
      </div>
      <div style="background:var(--brand-surface); border:1px solid var(--brand-border); border-radius:10px; padding:1.25rem;">
        <div style="font-size:1.5rem; margin-bottom:0.5rem;">🔍</div>
        <h3 style="font-weight:700; margin-bottom:0.4rem;">Protocol Deep Dives</h3>
        <p style="font-size:0.9rem; color:var(--brand-muted);">Weekly analysis on major protocols, on-chain movements, and ecosystem developments.</p>
      </div>
    </div>
  </section>

  <div class="subscribe-bar">
    <h2>Get crypto made clear, every week.</h2>
    <p>Independent editorial. Not financial advice. Unsubscribe any time.</p>
    <div class="subscribe-form">
      <input type="email" placeholder="your@email.com" aria-label="Email address" />
      <button class="btn">Subscribe — it's free</button>
    </div>
  </div>

  <section style="margin: 3rem 0;">
    <h2 style="font-size:0.85rem; font-weight:700; margin-bottom:1.5rem; color:var(--brand-muted); text-transform:uppercase; letter-spacing:0.05em;">Latest Articles</h2>
    <p style="color:var(--brand-muted); font-style:italic;">First issue coming soon. <a href="/articles">Browse the archive</a> once we launch.</p>
  </section>
</BaseLayout>
