---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allArticles = await getCollection('articles', ({ data }) => data.status === 'live');
allArticles.sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime());
const latestArticles = allArticles.slice(0, 5);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title="Chain Brief"
  description="Crypto made clear — from first principles to the latest signals. The independent crypto briefing for curious, intelligent readers."
>
  <section class="hero">
    <p class="hero-label">Crypto Intelligence</p>
    <h1 class="hero-headline">
      Crypto made clear —<br>from first principles to the latest signals.
    </h1>
    <p class="hero-sub">
      Whether you're new to crypto or deep in the ecosystem, Chain Brief gives you the
      <strong>clearest possible read</strong> on what's happening and why it matters.
      No trading advice. Just signal.
    </p>
    <div class="subscribe-form hero-form">
      <input type="email" placeholder="your@email.com" aria-label="Email address" />
      <button class="btn">Subscribe free</button>
    </div>
    <p class="hero-note">Free. Independent. Not financial advice.</p>
  </section>

  <hr class="divider" />

  <section class="coverage">
    <h2 class="section-label">What we cover</h2>
    <div class="coverage-grid">
      <div class="coverage-card">
        <div class="coverage-icon">📰</div>
        <h3>Daily Market Brief</h3>
        <p>The day's crypto news that matters — summarised clearly, without the noise.</p>
      </div>
      <div class="coverage-card">
        <div class="coverage-icon">🎓</div>
        <h3>Chain 101</h3>
        <p>Beginner guides: blockchains, wallets, DeFi, Layer 2s — explained from first principles.</p>
      </div>
      <div class="coverage-card">
        <div class="coverage-icon">🔍</div>
        <h3>Protocol Deep Dives</h3>
        <p>Weekly analysis on major protocols, on-chain movements, and ecosystem developments.</p>
      </div>
    </div>
  </section>

  {latestArticles.length > 0 ? (
    <section class="latest">
      <h2 class="section-label">Latest Articles</h2>
      <div class="article-list">
        {latestArticles.map(article => (
          <a href={`/articles/${article.slug}`} class="article-row">
            <div class="article-info">
              <div class="article-meta">
                <span class="article-cat">{article.data.category}</span>
                <span class="article-date">{formatDate(article.data.publishedDate)}</span>
              </div>
              <h3 class="article-title">{article.data.title}</h3>
              <p class="article-desc">{article.data.description}</p>
            </div>
            <div class="article-arrow" aria-hidden="true">&#8594;</div>
          </a>
        ))}
      </div>
      <a href="/articles" class="all-link">View all articles &rarr;</a>
    </section>
  ) : (
    <section class="latest">
      <h2 class="section-label">Latest Articles</h2>
      <p class="coming-soon">First issue coming soon. <a href="/articles">Browse the archive</a> once we launch.</p>
    </section>
  )}

  <div class="subscribe-bar">
    <h2>Get crypto made clear, every day.</h2>
    <p>Independent editorial. Not financial advice. Unsubscribe any time.</p>
    <div class="subscribe-form">
      <input type="email" placeholder="your@email.com" aria-label="Email address" />
      <button class="btn">Subscribe — it's free</button>
    </div>
  </div>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  .hero-label {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-accent);
    margin-bottom: 1rem;
  }

  .hero-headline {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--brand-muted);
    max-width: 520px;
    margin: 0 auto 2.5rem;
  }

  .hero-sub strong { color: var(--brand-text); }

  .hero-form {
    max-width: 420px;
    margin: 0 auto;
  }

  .hero-note {
    font-size: 0.8rem;
    color: var(--brand-muted);
    margin-top: 0.75rem;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--brand-border);
    margin: 2rem 0;
  }

  .section-label {
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--brand-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .coverage { margin: 3rem 0; }

  .coverage-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .coverage-card {
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 10px;
    padding: 1.25rem;
  }

  .coverage-icon { font-size: 1.5rem; margin-bottom: 0.5rem; }

  .coverage-card h3 {
    font-weight: 700;
    margin-bottom: 0.4rem;
    font-size: 0.95rem;
  }

  .coverage-card p {
    font-size: 0.9rem;
    color: var(--brand-muted);
  }

  .latest { margin: 3rem 0; }

  .article-list { display: flex; flex-direction: column; }

  .article-row {
    display: flex;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--brand-border);
    text-decoration: none;
    color: inherit;
    align-items: flex-start;
  }

  .article-row:first-child { padding-top: 0; }
  .article-row:hover .article-title { color: var(--brand-accent); }

  .article-info { flex: 1; min-width: 0; }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.3rem;
  }

  .article-cat {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-accent);
  }

  .article-date {
    font-size: 0.75rem;
    color: var(--brand-muted);
  }

  .article-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
    line-height: 1.35;
    color: var(--brand-text);
    transition: color 0.15s;
  }

  .article-desc {
    font-size: 0.85rem;
    color: var(--brand-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-arrow {
    color: var(--brand-border);
    font-size: 1rem;
    align-self: center;
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }

  .article-row:hover .article-arrow {
    color: var(--brand-accent);
    transform: translateX(3px);
  }

  .all-link {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--brand-accent-light);
    text-decoration: none;
  }

  .all-link:hover { text-decoration: underline; }

  .coming-soon {
    color: var(--brand-muted);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .article-arrow { display: none; }
    .article-desc { display: none; }
  }
</style>
