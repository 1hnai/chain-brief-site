---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  article?: boolean;
  publishedDate?: string;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/og-default.png',
  article = false,
  publishedDate,
} = Astro.props;

const siteName = 'Chain Brief';
const siteUrl = 'https://chainbrief.com';
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#080808" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    <meta name="twitter:site" content="@chainbrief" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": article ? "Article" : "WebSite",
      "name": siteName,
      "url": siteUrl,
      "description": "Crypto made clear — from first principles to the latest signals.",
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Barlow+Condensed:wght@700;900&display=swap" rel="stylesheet" />

    <style>
      :root {
        --bg:        #080808;
        --surface:   #0f0f0f;
        --surface2:  #141414;
        --neon:      #00f5ff;
        --neon-dim:  rgba(0, 245, 255, 0.12);
        --neon-glow: 0 0 8px rgba(0,245,255,0.7), 0 0 24px rgba(0,245,255,0.3);
        --green:     #00ff41;
        --magenta:   #ff0090;
        --text:      #e8e8e8;
        --muted:     #555;
        --border:    #1e1e1e;
        --border-bright: #2a2a2a;
        --max-w:     740px;
        --font-mono: 'Space Mono', 'Courier New', monospace;
        --font-display: 'Barlow Condensed', 'Arial Black', sans-serif;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: 16px; scroll-behavior: smooth; }

      body {
        font-family: var(--font-mono);
        background: var(--bg);
        color: var(--text);
        line-height: 1.7;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        /* scanline overlay */
        background-image:
          repeating-linear-gradient(
            0deg,
            transparent,
            transparent 2px,
            rgba(0,0,0,0.15) 2px,
            rgba(0,0,0,0.15) 4px
          );
      }

      a { color: var(--neon); text-decoration: none; }
      a:hover { text-decoration: underline; color: #fff; }

      /* ── HEADER ── */
      header {
        border-bottom: 2px solid var(--neon);
        padding: 0;
        position: relative;
      }

      header::after {
        content: '';
        position: absolute;
        bottom: -6px;
        left: 0;
        right: 0;
        height: 1px;
        background: var(--neon-dim);
      }

      .header-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
      }

      .logo {
        font-family: var(--font-display);
        font-weight: 900;
        font-size: 1.4rem;
        color: var(--text);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-shadow: var(--neon-glow);
        text-decoration: none;
      }

      .logo em {
        font-style: normal;
        color: var(--neon);
      }

      /* glitch effect on logo hover */
      .logo:hover {
        animation: glitch 0.3s steps(2) forwards;
        text-decoration: none;
      }

      @keyframes glitch {
        0%   { text-shadow: 2px 0 var(--magenta), -2px 0 var(--green); }
        25%  { text-shadow: -2px 0 var(--magenta), 2px 0 var(--green); }
        50%  { text-shadow: 2px 2px var(--neon), -2px -2px var(--magenta); }
        75%  { text-shadow: -1px 0 var(--green), 1px 0 var(--neon); }
        100% { text-shadow: var(--neon-glow); }
      }

      .header-status {
        font-size: 0.6rem;
        color: var(--green);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        margin-top: 2px;
      }

      .header-status::before {
        content: '● ';
        animation: blink 1.2s step-end infinite;
      }

      @keyframes blink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0; }
      }

      .logo-wrap { display: flex; flex-direction: column; gap: 0; }

      header nav ul {
        list-style: none;
        display: flex;
        gap: 0;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      header nav ul li a {
        color: var(--muted);
        padding: 0.4rem 0.9rem;
        border: 1px solid transparent;
        transition: all 0.1s;
        display: block;
      }

      header nav ul li a:hover {
        color: var(--neon);
        border-color: var(--neon);
        background: var(--neon-dim);
        text-decoration: none;
        text-shadow: var(--neon-glow);
      }

      /* ── MAIN ── */
      main {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 3rem 1.5rem;
        flex: 1;
        width: 100%;
      }

      /* ── SHARED COMPONENTS ── */
      .btn {
        padding: 0.55rem 1.2rem;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        font-weight: 700;
        cursor: pointer;
        border: 2px solid var(--neon);
        background: transparent;
        color: var(--neon);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.15s;
        white-space: nowrap;
        border-radius: 0;
      }

      .btn:hover {
        background: var(--neon);
        color: var(--bg);
        box-shadow: var(--neon-glow);
      }

      .subscribe-form {
        display: flex;
        gap: 0;
      }

      .subscribe-form input {
        flex: 1;
        padding: 0.55rem 1rem;
        border: 2px solid var(--border-bright);
        border-right: none;
        background: var(--surface);
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 0.8rem;
        border-radius: 0;
        outline: none;
        transition: border-color 0.15s;
      }

      .subscribe-form input:focus {
        border-color: var(--neon);
      }

      .subscribe-form input::placeholder {
        color: var(--muted);
      }

      /* ── SUBSCRIBE BAR ── */
      .subscribe-bar {
        border: 2px solid var(--border-bright);
        border-left: 4px solid var(--neon);
        padding: 2rem;
        margin: 3rem 0;
        background: var(--surface);
        position: relative;
      }

      .subscribe-bar::before {
        content: '// SUBSCRIBE';
        position: absolute;
        top: -0.65rem;
        left: 1rem;
        background: var(--surface);
        padding: 0 0.5rem;
        font-size: 0.65rem;
        color: var(--neon);
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      .subscribe-bar h2 {
        font-family: var(--font-display);
        font-weight: 900;
        font-size: 1.4rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 0.4rem;
      }

      .subscribe-bar p {
        color: var(--muted);
        font-size: 0.8rem;
        margin-bottom: 1.25rem;
        letter-spacing: 0.02em;
      }

      .subscribe-bar .subscribe-form {
        max-width: 420px;
      }

      /* ── FOOTER ── */
      footer {
        border-top: 2px solid var(--border-bright);
        padding: 2rem 1.5rem;
        font-size: 0.75rem;
        color: var(--muted);
      }

      .footer-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 2rem;
        flex-wrap: wrap;
      }

      .footer-brand { font-family: var(--font-display); font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); }

      footer nav { display: flex; gap: 1.5rem; }
      footer a { color: var(--muted); }
      footer a:hover { color: var(--neon); text-decoration: none; }

      .disclaimer {
        max-width: var(--max-w);
        margin: 1rem auto 0;
        font-size: 0.7rem;
        color: #333;
        border-top: 1px solid var(--border);
        padding-top: 1rem;
        letter-spacing: 0.02em;
      }

      @media (max-width: 600px) {
        .subscribe-form { flex-direction: column; }
        .subscribe-form input { border-right: 2px solid var(--border-bright); border-bottom: none; }
        .footer-inner { flex-direction: column; gap: 1rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="logo-wrap" style="text-decoration:none;">
          <span class="logo">Chain<em>Brief</em></span>
          <span class="header-status">SIGNAL ONLINE</span>
        </a>
        <nav>
          <ul>
            <li><a href="/articles">Archive</a></li>
            <li><a href="/about">About</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <span class="footer-brand">ChainBrief</span>
        <nav>
          <a href="/articles">Archive</a>
          <a href="/about">About</a>
          <a href="/rss.xml">RSS</a>
        </nav>
        <span>© {new Date().getFullYear()} Chain Brief</span>
      </div>
      <p class="disclaimer">NOT FINANCIAL ADVICE. Chain Brief is an independent editorial publication. Nothing published here constitutes investment advice or a recommendation to buy or sell any asset.</p>
    </footer>
  </body>
</html>
